# Cassette environment configuration.
# Copy to .env and fill in.

# Public URL the app is served from (used by Better-Auth and HLS link rewriting).
PUBLIC_URL="http://localhost:3000"

# Postgres connection. Used by app, pg-boss, and Drizzle.
DATABASE_URL="postgres://cassette:cassette@localhost:5432/cassette"

# Better-Auth secret. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="change-me-please-generate-32-bytes"
BETTER_AUTH_URL="http://localhost:3000"

# HLS signed-token secret for private videos. Generate with: openssl rand -hex 32
HLS_SIGNING_SECRET="change-me-please-generate-32-bytes-hex"

# Storage. MEDIA_SOURCE_PATH holds originals (Emby-style arbitrary path).
# MEDIA_HLS_PATH holds derived HLS segments and sprites; safe to wipe.
MEDIA_SOURCE_PATH="./media/source"
MEDIA_HLS_PATH="./media/hls"

# Upload size cap (bytes). 20 GiB default.
MAX_UPLOAD_BYTES="21474836480"

# Transcoding workers per app process (ffmpeg saturates CPU; 1 is the safe default).
TRANSCODE_CONCURRENCY="1"

# Optional NVENC for hardware encoding. Set to 1 if /dev/nvidia* is present
# and the ffmpeg build includes h264_nvenc.
ENABLE_NVENC="0"

# Bootstrap admin (only used on first boot if no users exist).
ADMIN_EMAIL="admin@local"
ADMIN_PASSWORD="please-change-me"
